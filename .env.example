# Copiar a .env.local y completar con las credenciales reales.
# NUNCA commitear .env.local.

# ── Supabase ──────────────────────────────────────────────────────────
# Settings → API en el dashboard de Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: solo server-side, bypassa RLS. NUNCA al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ── MercadoPago (Chile) ───────────────────────────────────────────────
# https://www.mercadopago.cl/developers/ → tu aplicación → Credenciales.
# Usar credenciales TEST hasta validar el flujo end-to-end.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
# Nota: MERCADOPAGO_WEBHOOK_SECRET ya no es requerido. El webhook usa
# fetch-based validation en lugar de HMAC.

# ── Resend ────────────────────────────────────────────────────────────
# https://resend.com/ → API Keys.
RESEND_API_KEY=
# El dominio del FROM debe estar verificado (registros DNS SPF/DKIM).
RESEND_FROM_EMAIL=ventas@camperooverland.cl

# ── App ───────────────────────────────────────────────────────────────
# Dev: http://localhost:3000
# Prod: https://camperooverland.cl
NEXT_PUBLIC_SITE_URL=http://localhost:3000
